# Copy this file to .df-factory.env if you want a custom local configuration.
# call-start-factory.bash loads it automatically before starting the router.

DF_AGENT_CMD='./df/agent-router/run-role-session.bash'
DF_AGENT_RUNNER='copilot'
DF_AGENT_MODEL='gpt-5.4'
DF_AGENT_MODE='autopilot'
DF_AGENT_IGNORE_TOKEN='true'
# Optional token-file override if you do want file-based auth:
# DF_AGENT_TOKEN_FILE='./token'
DF_FACTORY_ADAPTER='auto'
DF_FACTORY_MAX_ITERATIONS='300'

